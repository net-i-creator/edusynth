# ===== EduSynth Environment Configuration =====

# --- Application ---
APP_NAME=EduSynth
DEBUG=false
CORS_ORIGINS=["http://localhost:80","http://localhost:3000","http://localhost:5500","http://localhost:8766","http://127.0.0.1:8766","http://localhost"]

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://edusynth:edusynth@localhost:5432/edusynth
POSTGRES_PASSWORD=edusynth

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=2592000

# --- Auth ---
# Set to true when login/registration should be available
AUTH_ENABLED=false

# --- JWT ---
JWT_SECRET=change-me-to-a-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Yandex AI Studio ---
# Получить ключи: https://console.cloud.yandex.ru/ -> AI Studio
YANDEX_FOLDER_ID=
YANDEX_API_KEY=
YANDEX_GPT_MODEL=yandexgpt
YANDEX_ART_MODEL=yandexart
YANDEX_GPT_TEMPERATURE=0.7
YANDEX_GPT_MAX_TOKENS=4000

# --- Image illustrations ---
IMAGE_PROVIDER=web_search
IMAGE_MAX_COUNT=3
IMAGE_REHOST_S3=true
IMAGE_CANDIDATE_POOL=25
IMAGE_VISION_SHORTLIST=10
IMAGE_VISION_VERIFY=true
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- Yandex Object Storage (S3) ---
# Получить ключи: https://console.cloud.yandex.ru/ -> Object Storage
S3_ENDPOINT_URL=https://storage.yandexcloud.net
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=edusynth-images
S3_REGION=ru-central1
